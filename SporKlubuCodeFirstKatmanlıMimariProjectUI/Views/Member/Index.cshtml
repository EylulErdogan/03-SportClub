@model IEnumerable<SporKulubu.Model.Member>

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="card-title mb-0">Üye Listesi</h4>

                            <div>
                                <a href="@Url.Action("ExportToPdf", "Member")" class="btn btn-danger">
                                    PDF İndir
                                </a>

                                <a href="@Url.Action("ExportToExcel", "Member")" class="btn btn-success">
                                    Excel İndir
                                </a>

                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-plus"></i> Ekle
                                </a>
                            </div>
                        </div>

                        <div class="mb-3">
                            <input type="text"
                                   id="memberSearch"
                                   class="form-control"
                                   placeholder="Üye adı, telefon, email veya spor dalına göre ara..." />
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover" id="memberTable">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>İsim Soyisim</th>
                                        <th>Yaş</th>
                                        <th>Telefon</th>
                                        <th>Email</th>
                                        <th>Spor Dalı</th>
                                        <th>Düzenle</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>@item.FullName</td>
                                            <td>@item.Age</td>
                                            <td>@item.Phone</td>
                                            <td>@item.Email</td>
                                            <td>@item.Sport.SportName</td>
                                            <td>
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                                                    Güncelle
                                                </a>

                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                                    Sil
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("memberSearch").addEventListener("keyup", function () {
            var searchValue = this.value.toLowerCase();
            var rows = document.querySelectorAll("#memberTable tbody tr");

            rows.forEach(function (row) {
                var rowText = row.innerText.toLowerCase();

                if (rowText.includes(searchValue)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        });
    </script>
}